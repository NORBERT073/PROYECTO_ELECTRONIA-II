library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity almacenamient_de_clave_M1 is
    port(
        clk      : in  std_logic;
        rst      : in  std_logic;
        store_en : in  std_logic;                 -- pulso ENTER
        sw_key   : in  std_logic_vector(3 downto 0);
        key_out  : out std_logic_vector(3 downto 0)
    );
end entity;

architecture Behavioral of almacenamient_de_clave_M1 is
    signal key_reg : std_logic_vector(3 downto 0) := (others=>'0');
begin
    process(clk)
    begin
        if rising_edge(clk) then
            if rst = '1' then
                key_reg <= (others=>'0');
            elsif store_en = '1' then
                key_reg <= sw_key;
            end if;
        end if;
    end process;

    key_out <= key_reg;
end Behavioral;
