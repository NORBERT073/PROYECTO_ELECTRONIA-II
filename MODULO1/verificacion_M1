library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity verificacion_M1 is
    port(
        user_key  : in std_logic_vector(3 downto 0);
        stored_key: in std_logic_vector(3 downto 0);
        match     : out std_logic                -- 1 si coinciden
    );
end entity;

architecture Behavioral of verificacion_M1 is
begin
    match <= '1' when user_key = stored_key else '0';
end Behavioral;
