library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity tb_visualizacion_M1 is
end tb_visualizacion_M1;

architecture Behavioral of tb_visualizacion_M1 is

    -- Component Declaration
    component visualizacion_M1
        port(
            clk         : in  std_logic;
            rst         : in  std_logic;
            lock_active : in  std_logic;
            lock_value  : in  integer range 0 to 30;
            attempts    : in  integer range 0 to 5;
            seg_out     : out std_logic_vector(6 downto 0);
            an_out      : out std_logic_vector(3 downto 0);
            leds_out    : out std_logic_vector(4 downto 0)
        );
    end component;

    -- Inputs
    signal clk        : std_logic := '0';
    signal rst        : std_logic := '1';
    signal lock_active: std_logic := '0';
    signal lock_value : integer range 0 to 30 := 0;
    signal attempts   : integer range 0 to 5 := 5;

    -- Outputs
    signal seg_out  : std_logic_vector(6 downto 0);
    signal an_out   : std_logic_vector(3 downto 0);
    signal leds_out : std_logic_vector(4 downto 0);

    -- Clock period definitions
    constant CLK_PERIOD : time := 10 ns; -- 100 MHz

begin

    -- Instantiate the Unit Under Test (UUT)
    uut: visualizacion_M1
        port map (
            clk         => clk,
            rst         => rst,
            lock_active => lock_active,
            lock_value  => lock_value,
            attempts    => attempts,
            seg_out     => seg_out,
            an_out      => an_out,
            leds_out    => leds_out
        );

    -- Clock process
    clk_process : process
    begin
        clk <= '0';
        wait for CLK_PERIOD/2;
        clk <= '1';
        wait for CLK_PERIOD/2;
    end process;

    -- Stimulus process
    stim_proc: process
    begin
        -- Reset inicial
        rst <= '1';
        wait for 100 ns;
        rst <= '0';
        wait for 20 ns;

        -- Test 1: lock_active = '0' (display apagado)
        report "Test 1: lock_active = '0' - Display apagado";
        lock_active <= '0';
        lock_value <= 15;
        attempts <= 5;
        wait for 200 ns;

        -- Test 2: lock_active = '1' con valor 15 (dos dígitos)
        report "Test 2: lock_active = '1' con valor 15";
        lock_active <= '1';
        lock_value <= 15;
        attempts <= 4;
        wait for 500 ns;

        -- Test 3: lock_active = '1' con valor 7 (un dígito)
        report "Test 3: lock_active = '1' con valor 7 (un dígito)";
        lock_value <= 7;
        attempts <= 3;
        wait for 500 ns;

        -- Test 4: lock_active = '1' con valor 30 (dos dígitos)
        report "Test 4: lock_active = '1' con valor 30";
        lock_value <= 30;
        attempts <= 2;
        wait for 500 ns;

        -- Test 5: lock_active = '1' con valor 0
        report "Test 5: lock_active = '1' con valor 0";
        lock_value <= 0;
        attempts <= 1;
        wait for 500 ns;

        -- Test 6: lock_active = '0' nuevamente
        report "Test 6: lock_active = '0' nuevamente";
        lock_active <= '0';
        lock_value <= 25;
        attempts <= 0;
        wait for 300 ns;

        -- Test 7: Cambio rápido de valores con lock_active = '1'
        report "Test 7: Cambio rápido de valores";
        lock_active <= '1';
        for i in 0 to 5 loop
            lock_value <= i * 5; -- 0, 5, 10, 15, 20, 25
            attempts <= 5 - i;
            wait for 200 ns;
        end loop;

        -- Test 8: Todos los intentos posibles
        report "Test 8: Probando todos los valores de attempts";
        lock_active <= '1';
        lock_value <= 12;
        for i in 0 to 5 loop
            attempts <= i;
            wait for 300 ns;
        end loop;

        -- Finalizar simulación
        report "Simulación completada";
        wait;
    end process;

    -- Process para monitorear los cambios
    monitor_proc: process
    begin
        wait until rising_edge(clk);
        if lock_active = '1' then
            report "Time: " & time'image(now) & 
                   " | lock_value: " & integer'image(lock_value) &
                   " | attempts: " & integer'image(attempts) &
                   " | an_out: " & integer'image(to_integer(unsigned(an_out))) &
                   " | seg_out: " & integer'image(to_integer(unsigned(seg_out))) &
                   " | leds_out: " & integer'image(to_integer(unsigned(leds_out)));
        end if;
    end process;

end Behavioral;
